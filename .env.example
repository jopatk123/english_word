# 所有环境变量均为必填，留空会导致 Docker 部署失败或服务启动报错。

# 服务监听端口。
# Docker 部署示例：3010
PORT=3010

# SQLite 数据库文件路径。
# Docker 部署示例：/app/data/words.db
# 本地开发示例：./data/words.dev.db
DB_PATH=./data/words.db

# JWT 签名密钥。
# 请替换为长度足够、不可预测的随机字符串。
JWT_SECRET=replace-with-a-long-random-secret

# 超级管理员密码，用于登录 /super-admin。
ADMIN_PASSWORD=