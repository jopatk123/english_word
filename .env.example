# PORT、DB_PATH、JWT_SECRET、ADMIN_JWT_SECRET、ADMIN_PASSWORD_HASH 均为必填。
# 留空会导致 Docker 部署失败或服务启动报错。

# 服务监听端口。
# Docker 部署示例：3010
PORT=3010

# SQLite 数据库文件路径。
# Docker 部署示例：/app/data/words.db
# 本地开发示例：./data/words.dev.db
DB_PATH=./data/words.db

# JWT 签名密钥。
# 请替换为长度足够、不可预测的随机字符串。
JWT_SECRET=replace-with-a-long-random-secret

# 超级管理员 JWT 签名密钥。必须与 JWT_SECRET 使用不同随机字符串。
ADMIN_JWT_SECRET=replace-with-another-long-random-secret

# 超级管理员密码 bcrypt 哈希，用于登录 /super-admin。
# 生成示例：
# cd server && node -e "import bcrypt from 'bcryptjs'; console.log(await bcrypt.hash('your-admin-password', 12));"
ADMIN_PASSWORD_HASH=

# 允许跨域请求的来源白名单（逗号分隔，可选）。
# 未配置时禁止所有跨域请求（生产环境推荐留空，前后端同源部署）。
# 本地开发示例：ALLOWED_ORIGINS=http://localhost:5173
# ALLOWED_ORIGINS=
